                                    </div>
                                )}
                            </div>
                        )}
                </div>
                <div className='flex justify-end gap-2 p-6 border-t border-gray-200'>
                    <Button variant='outline' onClick={onClose}>
                        Close
                    </Button>
                </div>
            </div>
        </div>
    );
}
