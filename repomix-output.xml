CREATE INDEX idx_users_role ON users(role);
CREATE INDEX idx_stores_merchant ON stores(merchant_id);

--Tambahin average rating dan total rating
ALTER TABLE stores 
ADD COLUMN IF NOT EXISTS average_rating DECIMAL(2,1) DEFAULT (0.0);

