                                        </div>
                                        <div className='bg-gray-50 rounded-lg p-4 flex justify-center'>
                                            <img src={fullIdCardUrl} alt="ID Card"
                                             className='max-w-full max-h-[500px] object-contain rounded-lg shadow-md'/>
