                    </button>

                    <button onClick={() => setActiveTab('idcard')} 
                    className={`flex-1 px-6 py-3 text-sm font-semibold transition-colors ${activeTab === 'idcard' ? 'text-primary border-b-2 border-primary' 
                    : 'text-gray-500 hover:text-gray-700'}`}>
